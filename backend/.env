# ── All five protocols enabled ───────────────────────────────────────────────
# x402 (Coinbase/Cloudflare) — USDC on Solana, HTTP 402 standard
# Tempo (Stripe/Paradigm) — pathUSD stablecoin on Tempo L1 (EVM-compatible)
# AP2 (Google) — W3C Verifiable Credential authorization proofs
# ACP (OpenAI/Stripe) — Checkout session-based agent commerce
# AGTP (IETF Draft) — Agent identity, intent routing, HMAC-SHA256 signatures
X402_ENABLED=true
TEMPO_ENABLED=true
AP2_ENABLED=true
ACP_ENABLED=true
AGTP_ENABLED=true

# ── M32 discount gate ───────────────────────────────────────────────────────
# Discount stays off until SIWS wallet-signature verification ships. Without
# SIWS, the discount can be claimed by spoofing the x-wallet-address header.
M32_DISCOUNT_ENABLED=false
