generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model ApiRequest {
  id                 String   @id @default(cuid())
  requestId          String   @unique
  submissionSlug     String
  method             String
  statusCode         Int
  latencyMs          Int
  paymentVerified    Boolean  @default(false)
  errorCode          String?
  ipHash             String
  ap2MandateType     String?
  ap2MandateVerified Boolean  @default(false)
  ap2AgentId         String?
  acpSessionId       String?
  acpVerified        Boolean  @default(false)
  agtpIntentMethod   String?
  agtpAgentCertId    String?
  agtpVerified       Boolean  @default(false)
  protocolUsed       String?
  escrowStatus       String?
  escrowSkipReason   String?
  createdAt          DateTime @default(now())

  @@index([submissionSlug, createdAt])
  @@index([createdAt])
  @@index([statusCode])
  @@index([errorCode])
  @@index([ap2AgentId])
  @@index([acpSessionId])
  @@index([agtpAgentCertId])
  @@index([protocolUsed])
  @@index([escrowStatus])
}

model Submission {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  shortDescription String
  fullDescription  String?
  category         String
  websiteUrl       String
  endpointUrl      String?
  pricePerQuery    Float?
  paymentAddress   String?
  solanaAddress    String?
  creatorName      String
  creatorEmail     String
  logoUrl          String?
  twitterHandle    String?
  githubUrl        String?
  status           String   @default("pending")
  queryCount       Int      @default(0)
  lastQueriedAt    DateTime?
  managementToken  String?
  recoveryCode     String?
  recoveryExpiry   DateTime?
  isDeprecated       Boolean  @default(false)
  verificationToken  String?
  isVerified         Boolean  @default(false)
  verifyFailCount    Int      @default(0)
  lastVerifiedAt     DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([status, isDeprecated])
  @@index([category])
  @@index([status])
  @@index([creatorEmail])
}

model CheckoutSession {
  id          String    @id @default(cuid())
  sessionId   String    @unique
  resource    String
  amount      String
  currency    String    @default("USD")
  status      String    @default("pending")
  merchantId  String?
  agentId     String?
  metadata    String?
  expiresAt   DateTime
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([status])
  @@index([expiresAt])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([isRead])
}

model AgentSession {
  id              String    @id @default(cuid())
  agentId         String
  agentName       String?
  walletAddress   String?
  walletVerified  Boolean   @default(false)
  walletNonce     String?
  walletSignature String?
  nonceIssuedAt   DateTime?
  proofVerifiedAt DateTime?
  preferredProtocol String?
  totalRequests   Int       @default(0)
  successfulRequests Int    @default(0)
  apiKey          String    @unique
  isActive        Boolean   @default(true)
  lastActivityAt  DateTime?
  expiresAt       DateTime?
  budgetLimitUsd          Float?
  velocityLimitUsd        Float?
  alertThresholdPercent   Int?
  circuitBreakerTripped   Boolean   @default(false)
  circuitBreakerReason    String?
  circuitBreakerTrippedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  transactions    AgentTransaction[]

  @@index([agentId])
  @@index([apiKey])
  @@index([isActive])
  @@index([createdAt])
}

model AgentTransaction {
  id                    String   @id @default(cuid())
  sessionId             String
  service               String
  protocolUsed          String
  paymentMethod         String?
  priceQuoted           Float    @default(0)
  discountPercent       Float    @default(0)
  priceSettled          Float    @default(0)
  settled               Boolean  @default(false)
  settlementTxSignature String?
  statusCode            Int
  latencyMs             Int
  success               Boolean
  errorMessage          String?
  requestPayload        String?
  escrowStatus          String?
  escrowSkipReason      String?
  createdAt             DateTime @default(now())

  session         AgentSession @relation(fields: [sessionId], references: [id])

  @@index([sessionId, createdAt])
  @@index([sessionId, settled, createdAt])
  @@index([protocolUsed])
  @@index([paymentMethod])
  @@index([service])
  @@index([settled])
  @@index([createdAt])
  @@index([escrowStatus])
}

model ExternalService {
  id              String   @id @default(cuid())
  source          String
  sourceId        String
  slug            String   @unique
  name            String
  description     String?
  category        String?
  endpointUrl     String?
  websiteUrl      String?
  protocol        String
  protocols       String?
  network         String?
  asset           String?
  payTo           String?
  pricePerQuery   Float?
  priceCurrency   String   @default("USD")
  scheme          String?
  tags            String?
  metadata        String?
  iconUrl         String?
  popularity      Int      @default(0)
  verified        Boolean  @default(false)
  active          Boolean  @default(true)
  // Provider Qualification Layer — health-checked status of this listing.
  // unknown          = never checked
  // reachable        = TCP/TLS works, server responded (free/MCP HTTP)
  // challenge_valid  = returned a parseable x402/Tempo/etc. challenge
  // payment_verified = at least one settled tx via MPP32
  // broken           = persistent failure, malformed challenge, or non-compliant
  healthStatus      String    @default("unknown")
  healthCheckedAt   DateTime?
  healthError       String?
  healthFailCount   Int       @default(0)
  challengeSample   String?
  providerFeePayer  String?
  firstSeenAt     DateTime @default(now())
  lastSeenAt      DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([source, sourceId])
  @@index([source])
  @@index([protocol])
  @@index([category])
  @@index([active])
  @@index([popularity])
  @@index([lastSeenAt])
  @@index([healthStatus])
  @@index([healthCheckedAt])
}

model CatalogCrawlRun {
  id            String   @id @default(cuid())
  source        String
  status        String
  itemsFound    Int      @default(0)
  itemsAdded    Int      @default(0)
  itemsUpdated  Int      @default(0)
  itemsRemoved  Int      @default(0)
  durationMs    Int      @default(0)
  errorMessage  String?
  startedAt     DateTime @default(now())
  finishedAt    DateTime?

  @@index([source, startedAt])
  @@index([status])
}
