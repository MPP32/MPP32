{
  "name": "mpp32-mcp-server",
  "version": "1.2.4",
  "mcpName": "io.github.MPP32/mpp32-mcp-server",
  "description": "Payment layer for AI agents. One MCP, five protocols, thousands of paid APIs your agent can call.",
  "type": "module",
  "bin": {
    "mpp32-mcp-server": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "mpp",
    "mpp32",
    "machine-payments",
    "ai-agents",
    "agent-payments",
    "micropayments",
    "solana",
    "usdc",
    "x402",
    "tempo",
    "acp",
    "agent-commerce",
    "claude",
    "openai",
    "llm",
    "autonomous-agents",
    "crypto",
    "defi",
    "token-intelligence",
    "api-marketplace"
  ],
  "license": "MIT",
  "author": "MPP32 <admin@mpp32.org> (https://mpp32.org)",
  "homepage": "https://mpp32.org",
  "repository": {
    "type": "git",
    "url": "https://github.com/MPP32/MPP32"
  },
  "bugs": {
    "url": "https://github.com/MPP32/MPP32/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@solana-program/compute-budget": "^0.15.0",
    "@solana-program/token": "^0.13.0",
    "@solana/kit": "^6.9.0",
    "bs58": "^6.0.0",
    "tweetnacl": "^1.0.3",
    "viem": "^2.48.11",
    "zod": "^3.23.0"
  },
  "peerDependencies": {
    "mppx": ">=0.4.0"
  },
  "peerDependenciesMeta": {
    "mppx": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
